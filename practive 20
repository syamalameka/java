class Solution:
    def twoEditWords(self, queries: list[str], dictionary: list[str]) -> list[str]:
        ans = []

        for word in queries:
            for d in dictionary:
                diff = 0

                for i in range(len(word)):
                    if word[i] != d[i]:
                        diff += 1
                    if diff > 2:
                        break

                if diff <= 2:
                    ans.append(word)
                    break

        return ans
